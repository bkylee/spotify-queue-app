# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Where Spotify redirects after login (must match what you set in the Spotify Dashboard)
REDIRECT_URI=http://localhost:3000/callback

# After you run /auth/login once, paste the refresh token here so it persists
SPOTIFY_REFRESH_TOKEN=

# The host's name — shown in the guest UI as "Update [NAME]'s Queue"
HOST_NAME=Brian

# Password to access the admin page at /admin.html
ADMIN_PASSWORD=change_me_to_something_strong

# Port (optional, defaults to 3000)
PORT=3000
