# Copy this to terraform.tfvars and fill in your real values
# terraform.tfvars is gitignored — never commit it

app_name             = "spotify-queue-yourname"
resource_group_name  = "your-resource-group"
location             = "canadacentral"
sku_name             = "F1"
storage_account_name = "yourqueuestore"
host_name            = "Brian"

# The full resource ID of your App Service Plan
# Find it in Azure Portal → App Service Plan → Properties → Resource ID
service_plan_id = "/subscriptions/YOUR_SUB_ID/resourceGroups/YOUR_RG/providers/Microsoft.Web/serverFarms/YOUR_PLAN_NAME"

# Sensitive — never commit these
spotify_client_id     = "your_client_id_here"
spotify_client_secret = "your_client_secret_here"
spotify_refresh_token = ""
admin_password        = "change_me_to_something_strong"
